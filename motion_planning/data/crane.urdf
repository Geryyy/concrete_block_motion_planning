    <origin rpy="0 0 0" xyz="0 -0.06 0"/>
  </joint>
  <link name="zed2i_right_camera_optical_frame"/>
  <joint name="zed2i_right_camera_optical_joint" type="fixed">
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="-0.01 0 0"/>
    <parent link="zed2i_right_camera_frame"/>
    <child link="zed2i_right_camera_optical_frame"/>
  </joint>
  <!-- Main mounting joint -->
  <joint name="seyond_robin_mounting" type="fixed">
    <origin rpy="1.535 0.146 -0.402" xyz="-0.02 -0.18 0.0"/>
    <parent link="livox_frame"/>
    <child link="seyond"/>
  </joint>
  <!-- Main sensor frame -->
  <link name="seyond">
    <visual>
      <origin rpy="-1.5708 0 1.5708" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://sensor_description/meshes/seyond_robin_w.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="seyond_robin_mat"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.102 0.102 0.127"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="root_sensor_to_livox" type="fixed">
    <parent link="moved_with_q1"/>
    <child link="livox_frame"/>
    <origin rpy="-0.020179 0.525627 0.002835" xyz="0.166 0.697 2.695"/>
  </joint>
  <link name="livox_frame">
    <visual>
      <origin rpy="1.5707963267948966 0 3.141592653589793" xyz="0.038 0.04 -0.05"/>
      <geometry>
        <mesh filename="package://sensor_description/meshes/livox_avia.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1"/>
      </material>
    </visual>
  </link>
  <!-- to avoid joint reduction (lumping) -->
  <gazebo reference="root_sensor_to_livox">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <!-- TODO(anyone) why does the plugin not work with zed2i_left_camera_optical_frame -->
  <gazebo reference="livox_frame">
    <!-- <gazebo reference="zed2i_left_camera_optical_frame"> -->
    <sensor name="zed_detector_camera" type="logical_camera">
      <always_on>1</always_on>
      <!-- current update rate of live system -->
      <update_rate>2.5</update_rate>
      <logical_camera>
        <near>1.0</near>
        <far>15.0</far>
        <aspect_ratio>1.7777777777777777</aspect_ratio>
        <horizontal_fov>1.620887276327134</horizontal_fov>
      </logical_camera>
      <visualize>false</visualize>
      <plugin filename="libgazebo_ros_logical_camera.so" name="camera_detections">
        <ros>
          <namespace>perception</namespace>
          <remapping>~/detections:=logs/filtered</remapping>
        </ros>
        <!-- reference might not be existing -> gazebo merges fixed joints -->
        <!-- i.e., give it explicitly here -->
        <!-- <frame_name>zed2i_left_camera_optical_frame</frame_name> -->
        <frame_name>livox_frame</frame_name>
        <frame_is_sensor>false</frame_is_sensor>
        <model_whitelist>
          <prefix>Wood_Log</prefix>
        </model_whitelist>
        <pose_noise>
          <position>
            <x>
              <noise type="gaussian_quantized">
                <stddev>0.05</stddev>
                <precision>0.01</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian_quantized">
                <stddev>0.05</stddev>
                <precision>0.01</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian_quantized">
                <stddev>0.05</stddev>
                <precision>0.01</precision>
              </noise>
            </z>
          </position>
          <orientation>
            <x>
              <noise type="gaussian_quantized">
                <stddev>0.008726646259971648</stddev>
                <precision>0.005</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian_quantized">
                <stddev>0.008726646259971648</stddev>
                <precision>0.005</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian_quantized">
                <stddev>0.008726646259971648</stddev>
                <precision>0.005</precision>
              </noise>
            </z>
          </orientation>
        </pose_noise>
        <shape_noise>
          <length>
            <noise type="gaussian_quantized">
              <stddev>0.3</stddev>
              <precision>0.01</precision>
            </noise>
          </length>
          <radius>
            <noise type="gaussian_quantized">
              <stddev>0.05</stddev>
              <precision>0.005</precision>
            </noise>
          </radius>
        </shape_noise>
        <false_positive_p>0.001</false_positive_p>
        <!-- this fits Wood_Log_1 -->
        <!-- <log_radius>0.26</log_radius>
          <log_length>3.86</log_length> -->
        <!-- this fits Wood_Log_5 -->
        <log_radius>0.21</log_radius>
        <log_length>4.10</log_length>
        <pose_noise_published_scale>2.0</pose_noise_published_scale>
      </plugin>
    </sensor>
  </gazebo>
  <!-- IMU11 posital -->
  <joint name="imu11_mount" type="fixed">
    <!-- the sensor-fixed frame of output data -->
    <parent link="K0_mounting_base"/>
    <child link="imu11_origin"/>
    <origin rpy="3.141592653589793 -1.5707963267948966 0" xyz="0.15 -0.80 0.20"/>
  </joint>
  <link name="imu11_origin">
    <visual>
      <geometry>
        <box size="0.056 0.08 0.025 "/>
      </geometry>
      <origin xyz="0.0 0.0 0.0"/>
      <material name="lightgrey"/>
    </visual>
  </link>
  <!-- IMU12 posital -->
  <joint name="imu12_mount" type="fixed">
    <!-- the sensor-fixed frame of output data -->
    <parent link="K2_boom"/>
    <child link="imu12_origin"/>
    <origin rpy="3.141592653589793 0 1.0494333267948965" xyz="-3.22 0.1 -0.145"/>
  </joint>
  <link name="imu12_origin">
    <visual>
      <geometry>
        <box size="0.056 0.08 0.025 "/>
      </geometry>
      <origin xyz="0.0 0.0 0.0"/>
      <material name="lightgrey"/>
    </visual>
  </link>
  <!-- IMU13 posital -->
  <joint name="imu13_mount" type="fixed">
    <!-- the sensor-fixed frame of output data -->
    <parent link="K2_boom"/>
    <child link="imu13_origin"/>
    <origin rpy="0 0 1.3332733267948966" xyz="-0.80 -0.1 0.155"/>
  </joint>
  <link name="imu13_origin">
    <visual>
      <geometry>
        <box size="0.056 0.08 0.025 "/>
      </geometry>
      <origin xyz="0.0 0.0 0.0"/>
      <material name="lightgrey"/>
    </visual>
  </link>
  <!-- IMU14 posital -->
  <joint name="imu14_mount" type="fixed">
    <!-- the sensor-fixed frame of output data -->
    <parent link="K3_arm"/>
    <child link="imu14_origin"/>
    <origin rpy="1.5707963267948966 -0.041570 0" xyz="0.2425 0.22 0.89"/>
  </joint>
  <link name="imu14_origin">
    <visual>
      <geometry>
        <box size="0.056 0.08 0.025 "/>
      </geometry>
      <origin xyz="0.0 0.0 0.0"/>
      <material name="lightgrey"/>
    </visual>
  </link>
</robot>
